{
    ".site": {
        "apply": "Release.xml",
        "apply-module": "blog",
        "apply-setting": {
            ".tip": "详细参考 Release.xml 对 blog 模型的具体定义。涉及到复杂的交火设置须完整配置冲突部分。",
            "loader": [
                {"CSR": true},
                {"SSR": false},
                {"SSG": true}
            ],
            "client": {
                "cache": true
            },
            "server": {
                "index": "./index.html",
                "package": "./pages/home.html"
            },
            "fire": {
                "spiders": {
                    "server": "custom/%dynamicData%",
                    "server-js": "./application/app.mjs",
                    "interface": "MaicQCR://develop/tui/api/",
                    "interface-async": {
                        "content": ".env:localhost \n try:exec('send(已调取前端配置文件依照后端规则完成爬虫追踪测试！可以在当前终端环境核验数据是否符合预期。)')",
                        "type": "OpenKV:HOOK",
                        "method": "POST",
                        "track": "token/spiders",
                        "CR_console.title": "🌟 [OpenKV/QCR/Python] 前端配置校验 同步注入任务已启动，注意检测相关 .yaml 文件是否配置正确！"
                    },
                    "client": "%@server%",
                    "client-js": "./application/loader.js"
                }
            }
        },
        "develop": false,

        "Gateway": {
            "Trffic": "hosts/master:Gateway",
            "master": "private/cloudflare:3TH",
            "cache": {
                "enabled": true,
                "retry": true,
                "update": "12h"
            },
            "allow-list": true,
            "block-list": true
        },

        "net": {
            "domain": "blog.localhost",
            "port": 80
        },

        "Sheld": {
            ".tip": "部分功能须借助网关与后端联动实现，某些功能只是被动检测，而非主动防御。\n .site 配置仅在全局代表能被检索到",
            "3th-observe": [
                false
            ],
            "access": {
                "CSP": true,
                "COEP": true,
                "COOP": true,
                "CORS": true,
                "CORP": true,
                "HSTS": true,
                "HTTP-only": true,
                "Referrer": true,
                "X-Frame-Options": true,
                "X-Content-Type-Options": true
            },
            "attck": {
                "SRI": true,
                "XSS": true,
                "CSRF_token": true,
                "Trusted-Types": false
            },
            "report_security": true,
            "zero_trust": true
        }
    },
    
    "Release": {
        "baseline": {
            "alternate": {},
            "canonical": "",
            "siteName": "CodeBlog",
            "siteLang": "zh_CN",
            "siteICON": "https://avatars.githubusercontent.com/u/97972060",
            "siteDescription": "https://github.com/ZoMaii/ZoMaii/blob/main/README.md",
            "siteKeyWords":["AIGC", "Template", "codeblog"]
        },
        "Gateway": {
            "LLMs.txt": {},
            "llms-full.txt": {},
            "robots.txt": {
                "sitemap":{}
            },
            "rss.xml": {},
            "security.txt": {}
        },
        "Schema": {},
        "OG": {},
        "X": {}
    },

    "custom": {
        ".tip": "custom 属于暴露于顶层的自治域范围，一般用于集成其他服务 或 API。例如 Email、OAuth 或 其他已有站点。\n 请参考 Access token 授权层的概念自行设计。",

        "articles": {
            "open": {
                "alias": "dynamicData",
                "source": "api.localhost"
            },
            "description": "对接 apply-setting 模型设置的文章打包发布接口。适用于动态数据转换、配置内文件引用，避免 爬虫 数据获取不一致问题。",
            "standards": {
                "h1": "title",
                "time": "time",
                "summary": "description",
                "tag": "keywords",
                "author": "author",
                "cover": "image"
            }
        }
    }
}